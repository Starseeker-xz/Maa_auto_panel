{
  "schema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "visit_friends": {
        "type": "boolean",
        "title": "访问好友基建",
        "default": true,
        "description": "访问好友基建以获得信用。"
      },
      "shopping": {
        "type": "boolean",
        "title": "信用商店购物",
        "default": true,
        "description": "进入信用商店购物。"
      },
      "buy_first": {
        "type": "array",
        "title": "优先购买",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "优先购买商品名列表。",
        "x-linuxMaaManaged": "array"
      },
      "blacklist": {
        "type": "array",
        "title": "购物黑名单",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "第二轮购物避开的商品名列表。",
        "x-linuxMaaManaged": "array"
      },
      "force_shopping_if_credit_full": {
        "type": "boolean",
        "title": "信用溢出时无视黑名单",
        "default": false,
        "description": "信用即将溢出时无视黑名单。"
      },
      "only_buy_discount": {
        "type": "boolean",
        "title": "只购买折扣物品",
        "default": false,
        "description": "第二轮只购买折扣物品。"
      },
      "reserve_max_credit": {
        "type": "boolean",
        "title": "低于 300 信用时停止购买",
        "default": false,
        "description": "信用点低于 300 时停止购买。"
      },
      "credit_fight": {
        "type": "boolean",
        "title": "借助战获取信用",
        "default": false,
        "description": "借助战打一局 OF-1 以便第二天获得更多信用。"
      },
      "formation_index": {
        "type": "integer",
        "title": "助战编队",
        "default": 0,
        "minimum": 0,
        "maximum": 4,
        "description": "借助战使用的编队编号，0 表示当前编队。仅在启用借助战获取信用时有效。",
        "x-enabledWhen": [
          {
            "field": "credit_fight",
            "equals": true
          }
        ]
      }
    }
  },
  "general": [
    "visit_friends",
    "shopping",
    "buy_first",
    "blacklist"
  ],
  "advanced": [
    "force_shopping_if_credit_full",
    "only_buy_discount",
    "reserve_max_credit",
    "credit_fight",
    "formation_index"
  ]
}
