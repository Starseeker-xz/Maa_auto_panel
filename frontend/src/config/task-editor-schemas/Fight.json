{
  "schema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "stage": {
        "type": "string",
        "title": "关卡",
        "default": "",
        "description": "MaaCore 接收的单个关卡值；GUI 的候选关卡列表需要在前端或调度层提前解析为一个值。"
      },
      "medicine": {
        "type": "integer",
        "title": "最大使用理智药",
        "default": 0,
        "minimum": 0,
        "description": "最大使用理智药数量。"
      },
      "expiring_medicine": {
        "type": "integer",
        "title": "最大使用即将过期理智药",
        "default": 0,
        "minimum": 0,
        "description": "最大使用 48 小时内过期理智药数量。"
      },
      "medicine_expire_days": {
        "type": "integer",
        "title": "理智药过期天数阈值",
        "default": 2,
        "minimum": 0,
        "description": "过期理智药天数阈值；当前 maa-cli 文档示例中存在该参数。"
      },
      "stone": {
        "type": "integer",
        "title": "最大使用源石",
        "default": 0,
        "minimum": 0,
        "description": "最大使用源石数量。"
      },
      "times": {
        "type": "integer",
        "title": "战斗次数",
        "default": 2147483647,
        "minimum": 0,
        "description": "战斗次数上限。"
      },
      "series": {
        "type": "integer",
        "title": "连战次数",
        "default": 0,
        "description": "连战次数。-1 禁用切换，0 自动切换为当前可用的最大次数，1-6 为指定连战次数。",
        "oneOf": [
          {
            "const": -1,
            "title": "禁用切换"
          },
          {
            "const": 0,
            "title": "自动切换"
          },
          {
            "const": 1,
            "title": "指定 1 次"
          },
          {
            "const": 2,
            "title": "指定 2 次"
          },
          {
            "const": 3,
            "title": "指定 3 次"
          },
          {
            "const": 4,
            "title": "指定 4 次"
          },
          {
            "const": 5,
            "title": "指定 5 次"
          },
          {
            "const": 6,
            "title": "指定 6 次"
          }
        ]
      },
      "drops": {
        "type": "object",
        "title": "目标掉落",
        "additionalProperties": true,
        "default": {},
        "description": "目标掉落数量，键为 item_id，值为数量。"
      },
      "report_to_penguin": {
        "type": "boolean",
        "title": "汇报企鹅物流",
        "default": false,
        "description": "是否汇报企鹅物流数据。"
      },
      "penguin_id": {
        "type": "string",
        "title": "企鹅物流 ID",
        "default": "",
        "description": "企鹅物流用户 ID，留空则匿名。仅在启用企鹅物流汇报时有效。",
        "x-enabledWhen": [
          {
            "field": "report_to_penguin",
            "equals": true
          }
        ]
      },
      "report_to_yituliu": {
        "type": "boolean",
        "title": "汇报一图流",
        "default": false,
        "description": "是否汇报一图流数据。"
      },
      "yituliu_id": {
        "type": "string",
        "title": "一图流 ID",
        "default": "",
        "description": "一图流用户 ID，留空则匿名。仅在启用一图流汇报时有效。",
        "x-enabledWhen": [
          {
            "field": "report_to_yituliu",
            "equals": true
          }
        ]
      },
      "server": {
        "type": "string",
        "title": "服务器",
        "default": "CN",
        "description": "服务器，会影响掉落识别及上传。",
        "oneOf": [
          {
            "const": "CN",
            "title": "国服"
          },
          {
            "const": "US",
            "title": "国际服"
          },
          {
            "const": "JP",
            "title": "日服"
          },
          {
            "const": "KR",
            "title": "韩服"
          }
        ]
      },
      "client_type": {
        "type": "string",
        "title": "崩溃重连客户端",
        "default": "Bilibili",
        "description": "客户端版本。",
        "oneOf": [
          {
            "const": "Official",
            "title": "官服"
          },
          {
            "const": "Bilibili",
            "title": "Bilibili"
          },
          {
            "const": "txwy",
            "title": "腾讯服"
          },
          {
            "const": "YoStarEN",
            "title": "YoStar EN"
          },
          {
            "const": "YoStarJP",
            "title": "YoStar JP"
          },
          {
            "const": "YoStarKR",
            "title": "YoStar KR"
          }
        ]
      },
      "DrGrandet": {
        "type": "boolean",
        "title": "节省理智碎石模式",
        "default": false,
        "description": "节省理智碎石模式。"
      }
    }
  },
  "general": [
    "stage",
    "medicine",
    "medicine_expire_days",
    "stone",
    "times",
    "series"
  ],
  "advanced": [
    "expiring_medicine",
    "drops",
    "report_to_penguin",
    "penguin_id",
    "report_to_yituliu",
    "yituliu_id",
    "server",
    "client_type",
    "DrGrandet"
  ]
}
