{
  "schema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "stage": {
        "type": "array",
        "title": "关卡计划",
        "default": [],
        "description": "按顺序配置候选关卡；运行前由框架选择第一个当前可用关卡。",
        "x-frameworkManaged": "runtime-array",
        "x-optionsSource": "fight-stages",
        "x-allowCustom": true,
        "items": {
          "type": "string"
        }
      },
      "medicine": {
        "type": "integer",
        "title": "最大使用理智药",
        "default": 0,
        "minimum": 0
      },
      "medicine_expire_days": {
        "type": "integer",
        "title": "理智药过期天数阈值",
        "default": 2,
        "minimum": 0,
        "description": "无视最大使用理智药上限，无限使用过期时间小于该阈值的理智药。"
      },
      "stone": {
        "type": "integer",
        "title": "最大使用源石",
        "default": 0,
        "minimum": 0
      },
      "times": {
        "type": "integer",
        "title": "战斗次数",
        "default": 2147483647,
        "minimum": 0
      },
      "series": {
        "type": "integer",
        "title": "连战次数",
        "default": 0,
        "oneOf": [
          {
            "const": -1,
            "title": "禁用切换"
          },
          {
            "const": 0,
            "title": "自动切换"
          },
          {
            "const": 1,
            "title": "指定 1 次"
          },
          {
            "const": 2,
            "title": "指定 2 次"
          },
          {
            "const": 3,
            "title": "指定 3 次"
          },
          {
            "const": 4,
            "title": "指定 4 次"
          },
          {
            "const": 5,
            "title": "指定 5 次"
          },
          {
            "const": 6,
            "title": "指定 6 次"
          }
        ]
      },
      "drops": {
        "type": "object",
        "title": "目标掉落",
        "additionalProperties": true,
        "default": {},
        "description": "目标掉落数量，键为 item_id，值为数量。"
      },
      "report_to_penguin": {
        "type": "boolean",
        "title": "汇报企鹅物流",
        "default": false
      },
      "penguin_id": {
        "type": "string",
        "title": "企鹅物流 ID",
        "default": "",
        "description": "企鹅物流用户 ID，留空则匿名。仅在启用企鹅物流汇报时有效。",
        "x-enabledWhen": [
          {
            "field": "report_to_penguin",
            "equals": true
          }
        ]
      },
      "report_to_yituliu": {
        "type": "boolean",
        "title": "汇报一图流",
        "default": false
      },
      "yituliu_id": {
        "type": "string",
        "title": "一图流 ID",
        "default": "",
        "description": "一图流用户 ID，留空则匿名。仅在启用一图流汇报时有效。",
        "x-enabledWhen": [
          {
            "field": "report_to_yituliu",
            "equals": true
          }
        ]
      },
      "server": {
        "type": "string",
        "title": "服务器",
        "default": "CN",
        "description": "影响掉落识别与上传。",
        "oneOf": [
          {
            "const": "CN",
            "title": "国服"
          },
          {
            "const": "US",
            "title": "国际服"
          },
          {
            "const": "JP",
            "title": "日服"
          },
          {
            "const": "KR",
            "title": "韩服"
          }
        ]
      },
      "client_type": {
        "type": "string",
        "title": "崩溃重连客户端",
        "default": "Bilibili",
        "oneOf": [
          {
            "const": "Official",
            "title": "官服"
          },
          {
            "const": "Bilibili",
            "title": "Bilibili"
          },
          {
            "const": "txwy",
            "title": "腾讯服"
          },
          {
            "const": "YoStarEN",
            "title": "YoStar EN"
          },
          {
            "const": "YoStarJP",
            "title": "YoStar JP"
          },
          {
            "const": "YoStarKR",
            "title": "YoStar KR"
          }
        ]
      },
      "DrGrandet": {
        "type": "boolean",
        "title": "节省理智碎石模式",
        "default": false,
        "description": "勾选后 MAA 会在恰好回复 1 理智时碎石以避免浪费。"
      }
    }
  },
  "general": [
    "stage",
    "medicine",
    "medicine_expire_days",
    "stone",
    "times",
    "series",
    "client_type"
  ],
  "advanced": [
    "drops",
    "report_to_penguin",
    "penguin_id",
    "report_to_yituliu",
    "yituliu_id",
    "server",
    "DrGrandet"
  ]
}
