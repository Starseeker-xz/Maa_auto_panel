# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Frontend dependencies/build output
frontend/node_modules/
frontend/dist/

# Downloaded files
downloads/

# Local maa-cli and Linux MAA configs used for manual testing
config/maa/
config/linux-maa/

# Local Maa runtime: downloaded maa-cli/MaaCore/resources, logs, cache, generated config, and state
runtime/

# WebUI recycle bin for user-managed config files
config/maa/.trash/
config/linux-maa/.trash/

# User-uploaded local exports and temporary inputs
TEMP/

# Codex operational scratch/state that should not become project source
.codex/conversations/*/scratch/
frontend/.codex/

# Local debugging captures
debug/

# Cloned third-party source code for reference
external/

# Local framework state and durable runtime history generated by the WebUI
state/
history/
