# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Frontend dependencies/build output
frontend/node_modules/
frontend/dist/

# Current application-owned data and disposable cache roots
data/
cache/

# Legacy pre-migration roots (kept ignored until local data migration is complete)
downloads/
config/maa/
config/framework/

runtime/

# WebUI recycle bin for user-managed config files
config/maa/.trash/
config/framework/.trash/

# User-uploaded local exports and temporary inputs
TEMP/

# Codex operational scratch/state that should not become project source
.codex/conversations/*/scratch/
frontend/.codex/

debug/

# Cloned third-party source code for reference
external/

state/
history/
