# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Frontend dependencies/build output
frontend/node_modules/
frontend/dist/

# Downloaded files
downloads/

# Local Maa runtime: downloaded maa-cli/MaaCore/resources, logs, cache, generated config, and state
runtime/

# WebUI recycle bin for user-managed config files
config/maa/.trash/
config/linux-maa/.trash/

# User-uploaded local exports and temporary inputs
TEMP/

# Codex operational scratch/state that should not become project source
.codex/conversations/*/scratch/
frontend/.codex/

# Local debugging captures
debug/

# Local framework state: recent runs and scheduler bookkeeping
state/
